{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RenderMD",
  "version": "2.0.0-beta.4",
  "identifier": "io.github.rendermd.RenderMD",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RenderMD",
        "width": 1100,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-src preview: http://preview.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5QkY3RUNFQjJEMzMyRTQKUldUa010T3l6bjYvdVpqVnhKTDFNbTRuRnpHVVpFa0hpWUFtQ1lOQlNEMW54eUVDMGRPdFpXNXQK",
      "endpoints": [
        "https://github.com/imcmurray/RenderMD-Tauri/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["appimage", "deb", "rpm", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Markdown viewer/editor",
    "longDescription": "RenderMD opens .md files in a rendered preview by default and toggles to a syntax-highlighted editor. GFM tables, mermaid diagrams, GitHub alerts, emoji shortcodes, git history browsing."
  }
}
